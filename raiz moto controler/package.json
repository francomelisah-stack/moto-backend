{
  "name": "moto-controller",
  "version": "1.0.0",
  "description": "Control y seguridad de motocicleta via 4G LTE",
  "main": "index.js",
  "scripts": {
    "start":         "expo start",
    "android":       "expo start --android",
    "ios":           "expo start --ios",
    "build:android": "eas build --platform android --profile preview",
    "build:ios":     "eas build --platform ios     --profile preview",
    "build:prod":    "eas build --platform all     --profile production"
  },
  "dependencies": {
    "expo":                                      "~51.0.28",
    "expo-status-bar":                           "~1.12.1",
    "react":                                     "18.2.0",
    "react-native":                              "0.74.5",

    "expo-local-authentication":                 "~14.0.1",
    "expo-secure-store":                         "~13.0.2",
    "expo-notifications":                        "~0.28.19",
    "expo-device":                               "~6.0.2",

    "@react-navigation/native":                  "^6.1.18",
    "@react-navigation/native-stack":            "^6.9.26",
    "react-native-screens":                      "3.31.1",
    "react-native-safe-area-context":            "4.10.5",
    "react-native-gesture-handler":              "~2.16.1",

    "react-native-maps":                         "1.14.0",

    "mqtt":                                      "^4.3.7",

    "@react-native-async-storage/async-storage": "1.23.1"
  },
  "devDependencies": {
    "@babel/core":   "^7.25.0",
    "@types/react":  "~18.2.79",
    "typescript":    "^5.3.3"
  }
}
